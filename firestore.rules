rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // Restaurants Root Collection
    // ─────────────────────────────────────────────
    match /restaurants/{restaurantId} {

      // Public can read restaurant basic info
      allow read: if true;

      // Allow onboarding to create restaurant
      allow create: if true;

      // Allow restaurant updates (e.g. settings) if admin or during onboarding
      allow update: if true;

      // All subcollections: menu, orders, tables, settings, etc.
      match /{subcol}/{docId=**} {
        allow read, write: if true;
      }
    }

    // ─────────────────────────────────────────────
    // Users Collection (SaaS Profiles)
    // ─────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if true;
    }

    // ─────────────────────────────────────────────
    // Customers Collection
    // ─────────────────────────────────────────────
    match /customers/{custId} {

      // Anyone can register
      allow create: if true;

      // Only the customer can read/update/delete their own document
      allow read, update, delete: if request.auth != null 
                                  && request.auth.uid == custId;
    }

    // ─────────────────────────────────────────────
    // Additional Collection (myCollection)
    // ─────────────────────────────────────────────
    match /myCollection/{documentId} {

      // Public read access
      allow read: if true;

      // Only authenticated users can write
      allow write: if request.auth != null;
    }
  }
}
