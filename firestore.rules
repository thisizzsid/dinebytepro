rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // Restaurants Root Collection
    // ─────────────────────────────────────────────
    match /restaurants/{restaurantId} {

      // Public can read restaurant basic info
      allow read: if true;

      // Allow onboarding to create restaurant
      allow create: if true;

      // Prevent direct updates/deletes (handle via backend later)
      allow update, delete: if false;

      // All subcollections: menu, orders, tables, billing, etc.
      match /{subcol}/{docId=**} {

        // Public read (QR menus, public menu view, etc.)
        allow read: if true;

        // Only authenticated users can write
        allow write: if request.auth != null;
      }
    }

    // ─────────────────────────────────────────────
    // Customers Collection
    // ─────────────────────────────────────────────
    match /customers/{custId} {

      // Anyone can register
      allow create: if true;

      // Only the customer can read/update/delete their own document
      allow read, update, delete: if request.auth != null 
                                  && request.auth.uid == custId;
    }

    // ─────────────────────────────────────────────
    // Additional Collection (myCollection)
    // ─────────────────────────────────────────────
    match /myCollection/{documentId} {

      // Public read access
      allow read: if true;

      // Only authenticated users can write
      allow write: if request.auth != null;
    }
  }
}
